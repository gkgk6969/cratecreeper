# Anthropic — server-side only, never shipped to client or extension
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Service role — server-side only. Bypasses RLS. Never expose to client/extension.
SUPABASE_SERVICE_ROLE_KEY=ey...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Public site URL (used for Stripe redirect URLs and auth callback)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chrome extension id, used by the dashboard to message the extension for pairing
NEXT_PUBLIC_EXTENSION_ID=

# Gatekeep iOS app — Apple App Store link for wordmark headers
NEXT_PUBLIC_GATEKEEP_APP_STORE_URL=https://apps.apple.com/app/id6748489550

# Comma-separated emails allowed to bypass the daily extract limit
# (server-side only). Use sparingly — every extract costs Claude tokens.
UNLIMITED_EMAILS=
