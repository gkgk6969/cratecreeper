{
  "name": "crate-digger",
  "version": "0.1.0",
  "description": "Screenshot to Rekordbox crate in 2 minutes. For DJs.",
  "main": "src/main/main.js",
  "author": "CrateDigger",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:swift": "swiftc -O resources/ocr/AppleOCR.swift -o resources/ocr/apple-ocr -framework Vision -framework AppKit -framework Foundation",
    "build:vite": "vite build",
    "build": "npm run build:swift && npm run build:vite && electron-builder",
    "postinstall": "npm run build:swift || echo 'Swift compile skipped (non-mac or swiftc unavailable)'"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "electron-store": "^8.2.0",
    "music-metadata": "^7.14.0",
    "string-similarity": "^4.0.4",
    "ws": "^8.20.0",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cratedigger.app",
    "productName": "cratecreep",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "index.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/ocr/apple-ocr",
        "to": "resources/ocr/apple-ocr"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg",
      "icon": "resources/icon.icns"
    }
  }
}
