{
  "manifest_version": 3,
  "name": "Gatekeep · cratecreep",
  "version": "1.0.4",
  "description": "Pairs with the Gatekeep cratecreep web app to fill your Beatport cart from a tracklist screenshot.",
  "permissions": ["tabs", "storage", "alarms", "scripting"],
  "host_permissions": [
    "*://*.beatport.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:3001/*",
      "https://cratecreeper-kh9c.vercel.app/*"
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Gatekeep · cratecreep"
  },
  "content_scripts": [
    {
      "matches": ["*://*.beatport.com/*"],
      "js": ["content/selectors.js", "content/string-similarity.js", "content/beatport.js"],
      "run_at": "document_idle"
    }
  ]
}
